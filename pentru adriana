<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pentru Adriana ❤️ Ionuț</title>

<style>
body{
    margin:0;
    padding:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background: linear-gradient(135deg,#ff758c,#ff7eb3);
    font-family: 'Arial', sans-serif;
    overflow:hidden;
    text-align:center;
    color:white;
}

.container{
    z-index:2;
}

h1{
    font-size:32px;
    margin-bottom:10px;
}

#mesaj{
    margin-top:15px;
    font-size:20px;
    max-width:350px;
    min-height:50px;
}

button{
    margin-top:20px;
    padding:12px 25px;
    border:none;
    border-radius:30px;
    background:white;
    color:#ff4d6d;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    transform:scale(1.1);
}

.heart{
    position:absolute;
    font-size:20px;
    animation:float 6s linear infinite;
    pointer-events:none;
}

@keyframes float{
    0%{transform:translateY(100vh);}
    100%{transform:translateY(-10vh);}
}
</style>
</head>

<body>

<div class="container">
    <h1>Adriana ❤️ Ionuț</h1>
    <p id="mesaj"></p>
    <button onclick="iarta()">Te iert ❤️</button>
</div>

<script>
// Mesaj animat literă cu literă
const mesajOriginal = "Îmi pare rău... fără tine nu e la fel.";
const mesajFinal = "Promit că o să fie mai frumos ca niciodată ❤️";
const mesajElem = document.getElementById("mesaj");

function scrieMesaj(text, elem, interval=50){
    elem.innerHTML = "";
    let i = 0;
    const timer = setInterval(() => {
        elem.innerHTML += text[i];
        i++;
        if(i >= text.length) clearInterval(timer);
    }, interval);
}

// Start mesaj inițial
scrieMesaj(mesajOriginal, mesajElem);

// Buton Te iert
function iarta(){
    scrieMesaj(mesajFinal, mesajElem);
}

// Inimioare animate
function createHeart(){
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML="❤️";
    heart.style.left=Math.random()*100+"vw";
    heart.style.fontSize=(Math.random()*25+15)+"px";
    heart.style.animationDuration=(4 + Math.random()*3)+"s";
    document.body.appendChild(heart);

    setTimeout(()=>{heart.remove();},7000);
}

setInterval(createHeart,400);
</script>

</body>
</html>
